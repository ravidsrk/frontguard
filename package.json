{
  "name": "frontguard-monorepo",
  "private": true,
  "description": "AI-powered frontend visual regression testing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/frontguard.git"
  },
  "bugs": {
    "url": "https://github.com/ravidsrk/frontguard/issues"
  },
  "homepage": "https://frontguard.dev",
  "workspaces": [
    "packages/*",
    "apps/*",
    "integrations/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=packages/cloud-api",
    "build:cli": "npm run build --workspace=packages/cli",
    "build:web": "npm run build --workspace=apps/web",
    "stats": "npx tsx scripts/stats.ts",
    "sync-version": "npx tsx scripts/sync-version.ts",
    "sync-version:check": "npx tsx scripts/sync-version.ts --check",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "release": "npm run build && changeset publish",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/instrumentation-http": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.219.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-grpc-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "next": "16.2.9",
    "protobufjs": "^7.4.0",
    "shell-quote": "^1.8.4",
    "@grpc/grpc-js": "^1.14.4",
    "fast-xml-builder": "^1.1.7",
    "form-data": "^4.0.5",
    "hono": "^4.12.26",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "undici": "^7.28.0",
    "ws": "^8.21.0",
    "postcss": "^8.5.10",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "1.61.0",
    "react-router-dom": "^6.30.4"
  },
  "lint-staged": {
    "packages/cli/src/**/*.ts": [
      "eslint --fix --config packages/cli/eslint.config.js"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.js"
    ]
  }
}
