{
  "name": "frontguard",
  "version": "0.1.0",
  "description": "AI-powered frontend visual regression testing. Detect, understand, and fix visual bugs before production.",
  "type": "module",
  "bin": {
    "frontguard": "./dist/cli/index.js"
  },
  "main": "./dist/core/pipeline.js",
  "types": "./dist/core/pipeline.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/pipeline.js",
      "types": "./dist/core/pipeline.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "visual-regression",
    "testing",
    "playwright",
    "screenshot",
    "ai",
    "frontend",
    "ci"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/frontguard"
  },
  "homepage": "https://frontguard.dev",
  "bugs": {
    "url": "https://github.com/ravidsrk/frontguard/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
