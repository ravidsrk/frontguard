{
  "name": "frontguard",
  "version": "0.1.0",
  "description": "AI-powered frontend visual regression testing. Detect, understand, and fix visual bugs before production.",
  "type": "module",
  "bin": {
    "frontguard": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork --exclude='test/e2e/**'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "visual-regression",
    "testing",
    "playwright",
    "screenshot",
    "ai",
    "frontend",
    "ci"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "action.yml",
    "Dockerfile",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/frontguard"
  },
  "homepage": "https://frontguard.dev",
  "bugs": {
    "url": "https://github.com/ravidsrk/frontguard/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.158.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "hono": "^4.12.9",
    "ora": "^8.0.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.0"
  },
  "author": "Ravid <ravidsrk@gmail.com>"
}
