{
  "name": "@frontguard/cli",
  "version": "0.2.0",
  "description": "AI-powered frontend visual regression testing. Detect, understand, and fix visual bugs before production.",
  "type": "module",
  "bin": {
    "frontguard": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --pool=forks --exclude='test/e2e/**'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "visual-regression",
    "testing",
    "playwright",
    "screenshot",
    "ai",
    "frontend",
    "ci"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "action.yml",
    "Dockerfile",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/frontguard"
  },
  "homepage": "https://frontguard.dev",
  "bugs": {
    "url": "https://github.com/ravidsrk/frontguard/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@daytonaio/sdk": "^0.180.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "hono": "^4.12.9",
    "ora": "^9.3.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "author": "Ravindra Kumar <ravidsrk@gmail.com>"
}
