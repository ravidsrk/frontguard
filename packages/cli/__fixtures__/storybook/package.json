{
  "name": "frontguard-fixture-storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Real Storybook 8 fixture used by packages/cli tests and as a runnable demo target.",
  "scripts": {
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build -o storybook-static",
    "preview": "storybook dev -p 6006 --no-open --quiet"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "storybook": "^8.6.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
