{
  "name": "@frontguard/cloud-api",
  "version": "0.2.1",
  "private": true,
  "description": "Cloud API service for Frontguard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ravidsrk/frontguard.git",
    "directory": "packages/cloud-api"
  },
  "bugs": {
    "url": "https://github.com/ravidsrk/frontguard/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./render-target": {
      "import": "./src/security/render-target.ts",
      "types": "./src/security/render-target.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/index.ts",
    "build": "node ../../scripts/sync-openapi.mjs && tsup src/index.ts --format esm --dts",
    "deploy": "tsx scripts/check-wrangler-placeholders.ts && wrangler deploy",
    "db:migrate": "wrangler d1 execute frontguard --file=src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute frontguard --local --file=src/db/schema.sql",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@daytona/sdk": "^0.189.0",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.6.0",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
